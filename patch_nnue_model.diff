    for (int i = 0; i < hiddenSize; i++) {
      float sum = hiddenBiases[i];
      for (int j = 0; j < 864; j++) {
        sum += hiddenWeights[i][j] * input[j];
      }
      // Clipped ReLU
      hiddenLayer[i] = Math.max(0.0f, Math.min(127.0f, sum));
    }

    float output = outputBias;
    for (int i = 0; i < hiddenSize; i++) {
      output += outputWeights[i] * hiddenLayer[i];
